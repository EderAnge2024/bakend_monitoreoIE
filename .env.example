PORT=5000
NODE_ENV=production
DB_USER=your_db_user
DB_HOST=your_db_host
DB_NAME=your_db_name
DB_PASSWORD=your_db_password
DB_PORT=5432
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Google Drive (Set to true if using Google Drive API)
USE_GOOGLE_DRIVE=false
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_root_folder_id

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://your_domain.com/api/documentos/auth/callback

# Email Configuration
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_app_specific_password
FRONTEND_URL=http://your_domain.com
